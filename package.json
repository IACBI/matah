{
  "name": "matah",
  "version": "0.1.0",
  "private": true,
  "description": "Matah - a Jackbox-style multiplayer party game",
  "author": "𝓐.𝓒.𝓑",
  "license": "MIT",
  "keywords": [
    "party-game",
    "multiplayer",
    "socket.io",
    "react",
    "typescript",
    "websocket"
  ],
  "workspaces": [
    "server",
    "client",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "build": "npm --workspace client run build",
    "start": "npm --workspace server run start",
    "typecheck": "npm --workspace server run typecheck && npm --workspace client run typecheck",
    "test:e2e": "node tests/e2e-test.mjs",
    "test:reconnect": "node tests/reconnect-test.mjs",
    "test:playagain": "node tests/playagain-test.mjs",
    "test:csr": "node tests/csr-test.mjs",
    "test:disconnect": "node tests/disconnect-skip-test.mjs",
    "test:features": "node tests/new-features-test.mjs",
    "test:hosttools": "node tests/host-tools-test.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
